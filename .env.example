# ClipPilot — copy to .env and fill in. ALL secrets are env-only (never hardcode).

# --- Redis (redis-stack: RediSearch + RedisJSON needed for vector search) ---
REDIS_URL=redis://redis:6379/0

# --- OpenAI (reasoning + embeddings) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
EMBED_MODEL=text-embedding-3-small
# Dashboard Copilot CHAT model ONLY (Lane D). Keep this a FAST chat model — heavy
# reasoning models stall the sidebar chat for minutes. Does NOT affect OPENAI_MODEL.
COPILOT_MODEL=gpt-4o-mini

# --- Discovery (Lane A) ---
YOUTUBE_API_KEY=
LISTENNOTES_API_KEY=
DISCOVERY_TOP_N=5
ORCHESTRATOR_INTERVAL_SECONDS=120
DISCOVERY_MAX_SOURCE_DURATION_SEC=1800

# --- Engine (Lane C) ---
# Real pipeline: yt-dlp transcript + GPT moment detection (needs OPENAI_API_KEY).
OPENSHORTS_URL=http://engine:8001
OPENSHORTS_API_URL=http://localhost:8010
OPENSHORTS_PUBLIC_URL=http://localhost:8010
OPENSHORTS_TIMEOUT_SECONDS=600
ENGINE_POLL_TIMEOUT_SECONDS=900
ENGINE_SCORING_PROVIDER=openai   # openai | gemini

# --- Title headline overlay (Lane C, engine/overlay.py) ---
# Each clip gets ONE GPT-generated title (engine/titles.py) used BOTH as the YouTube title
# at upload AND burned across the top of the vertical short so the audience sees it. The
# burn is a static headline overlay (Pillow PNG + ffmpeg overlay) — OpenShorts still does
# all cutting/reframing/word-synced captions. Needs ffmpeg+ffprobe on PATH; degrades to the
# un-titled clip if either is missing. Set ENGINE_BURN_TITLE=false to skip the burn.
ENGINE_BURN_TITLE=true
# Browser-facing base URL for engine-served media (the titled clip in the dashboard player).
# Keep this browser-reachable (NOT host.docker.internal). Engine maps /media at this host.
ENGINE_MEDIA_PUBLIC_URL=http://localhost:8001
# Optional bold .ttf/.ttc for the title text; otherwise common system fonts are tried and
# Pillow's bundled scalable font is the final fallback (so text always renders).
# TITLE_FONT_FILE=/System/Library/Fonts/Supplemental/Arial Bold.ttf

# --- Most-replayed source selection (Lane C) ---
# When on, the engine reads YouTube's "most replayed" heatmap (the rewatch graph on the
# scrubber, via yt-dlp) and hands OpenShorts only a short window around the biggest
# peak(s) — the moments viewers actually replay. Videos with no heatmap fall back to a
# single best ~window-sized window from captions (never a giant chunk). OpenShorts still
# does all detection/cutting/reframing/captions.
MOST_REPLAYED_SEGMENTS=true
MOST_REPLAYED_WINDOW_SECONDS=120
# By default only the single tallest peak is grabbed. A secondary peak is ALSO grabbed
# (as its own window) only when its replay height is near-equal to the top peak — i.e.
# value >= MOST_REPLAYED_PEAK_SIMILARITY * top_value. MOST_REPLAYED_MAX_SEGMENTS caps how
# many windows we ever download (overlapping windows are merged). Total bounded download =
# MOST_REPLAYED_MAX_SEGMENTS * MOST_REPLAYED_WINDOW_SECONDS (e.g. 3 * 120s = 6 min max).
MOST_REPLAYED_PEAK_SIMILARITY=0.9
MOST_REPLAYED_MAX_SEGMENTS=3
# Transcript is a SECONDARY signal — the heatmap above is ALWAYS primary. For each replay
# peak we score the caption text in its window for "punchiness" (controversy / shock /
# quotable language) and add a small, BOUNDED boost: final = intensity + WEIGHT * norm_score
# (norm_score in 0..1). WEIGHT is small enough (0.25) that a clearly taller peak always wins;
# the transcript only reranks peaks that are already near-equal in replay height and never
# invents a window. Set to 0 to disable the transcript boost entirely (heatmap-only).
MOST_REPLAYED_TRANSCRIPT_WEIGHT=0.25
# Music-only intro guard: if a candidate window STARTS within the first N seconds AND its
# captions are only music/SFX cues ("[Music]", "♪", "[Applause]") or near-empty, skip it and
# prefer a later real-speech peak. Videos with REAL speech in the intro are kept; videos with
# NO captions at all are left untouched (heatmap is primary, so we never wrongly nuke them).
MOST_REPLAYED_INTRO_SKIP_SECONDS=120

# --- Upload-Post (Lane C posting to TikTok/IG/YouTube) ---
# Required for REAL rendering+posting + performance metrics. Without these, clips are
# detected (real moments) but render_status=pending / post_status=not_posted.
UPLOAD_POST_API_KEY=

# --- Direct YouTube upload (Lane D dashboard, Google OAuth "Web application" client) ---
# Lets you publish clips straight to a connected YouTube channel from the dashboard, and
# switch the target account in-browser. The redirect URI must EXACTLY match the one in the
# Google Cloud Console OAuth client. Scope used: youtube.upload.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Performance (Lane B) ---
PATTERN_REFRESH_SECONDS=300

# --- Team chat / agent "Slack" (the agent_chat worker) ---
# The four lanes appear as peer teammates (Scout/Cutter/Coach/Pilot) that converse in
# channels + DMs. Conversation is REAL LLM; with no OPENAI_API_KEY it falls back to short
# templated lines so the workspace still talks. CHAT_MODEL should be a FAST chat model.
CHAT_MODEL=gpt-4o-mini
CHAT_ENABLED=1               # set 0 to disable the team-chat worker
CHAT_STANDUP=1               # Pilot posts an opening standup to spark a round
CHAT_MAX_THREAD_TURNS=4      # cap auto-replies per conversation thread (loop guard)
CHAT_MAX_REPLIES_PER_MSG=2   # how many peers may answer a single message
CHAT_REPLY_COOLDOWN_SEC=2    # min seconds between posts from the same agent
CHAT_TAIL_BLOCK_MS=4000      # how long to block waiting for new chat messages

# --- Service URLs (for dashboard bridge) ---
# Local dev (no Docker): use localhost. Docker Compose: use service hostnames.
DISCOVERY_API_URL=http://localhost:8000
NEXT_PUBLIC_DISCOVERY_API_URL=http://localhost:8000
