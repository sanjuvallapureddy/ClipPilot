# ClipPilot — copy to .env and fill in. ALL secrets are env-only (never hardcode).

# --- Redis (redis-stack: RediSearch + RedisJSON needed for vector search) ---
REDIS_URL=redis://redis:6379/0

# --- OpenAI (reasoning + embeddings) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
EMBED_MODEL=text-embedding-3-small

# --- Discovery (Lane A) ---
YOUTUBE_API_KEY=
LISTENNOTES_API_KEY=
DISCOVERY_TOP_N=5
ORCHESTRATOR_INTERVAL_SECONDS=120

# --- Engine (Lane C) ---
# Real pipeline: yt-dlp transcript + GPT moment detection (needs OPENAI_API_KEY).
OPENSHORTS_URL=http://engine:8001
ENGINE_SCORING_PROVIDER=openai   # openai | gemini

# --- Upload-Post (Lane C posting to TikTok/IG/YouTube) ---
# Required for REAL rendering+posting + performance metrics. Without these, clips are
# detected (real moments) but render_status=pending / post_status=not_posted.
UPLOAD_POST_API_KEY=

# --- Direct YouTube upload (Lane D dashboard, Google OAuth "Web application" client) ---
# Lets you publish clips straight to a connected YouTube channel from the dashboard, and
# switch the target account in-browser. The redirect URI must EXACTLY match the one in the
# Google Cloud Console OAuth client. Scope used: youtube.upload.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Performance (Lane B) ---
PATTERN_REFRESH_SECONDS=300

# --- Service URLs (for dashboard bridge) ---
DISCOVERY_API_URL=http://discovery-orchestrator:8000
NEXT_PUBLIC_DISCOVERY_API_URL=http://localhost:8000
