# ClipPilot — copy to .env and fill in. ALL secrets are env-only (never hardcode).

# --- Redis (redis-stack: RediSearch + RedisJSON needed for vector search) ---
REDIS_URL=redis://redis:6379/0

# --- OpenAI (reasoning + embeddings) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# --- Discovery (Lane A) ---
YOUTUBE_API_KEY=
LISTENNOTES_API_KEY=
DISCOVERY_TOP_N=5
ORCHESTRATOR_INTERVAL_SECONDS=120

# --- Engine / OpenShorts (Lane C) ---
# MOCK = no real rendering (works end-to-end today). REAL = call vendored OpenShorts.
ENGINE_MODE=MOCK
OPENSHORTS_URL=http://openshorts:8001
ENGINE_SCORING_PROVIDER=openai   # openai | gemini
GEMINI_API_KEY=

# --- Upload-Post (Lane C posting to TikTok/IG/YouTube). Sandbox by default. ---
UPLOAD_POST_API_KEY=
UPLOAD_POST_SANDBOX=1

# --- Performance (Lane B) ---
PERFORMANCE_SIMULATE=1
PATTERN_REFRESH_SECONDS=300

# --- Service URLs (for dashboard bridge) ---
DISCOVERY_API_URL=http://discovery-orchestrator:8000
NEXT_PUBLIC_DISCOVERY_API_URL=http://localhost:8000
