# ClipPilot — copy to .env and fill in. ALL secrets are env-only (never hardcode).

# --- Redis (redis-stack: RediSearch + RedisJSON needed for vector search) ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI (reasoning + embeddings) ---
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-5.5
EMBED_MODEL=text-embedding-3-small
# Dashboard Copilot CHAT model ONLY — fast, low-latency. Does NOT affect OPENAI_MODEL.
COPILOT_MODEL=gpt-4o-mini

# --- Discovery (Lane A) ---
YOUTUBE_API_KEY=
LISTENNOTES_API_KEY=
DISCOVERY_TOP_N=5
# Source length for OpenShorts clip detection. "medium" (4-20 min) is the sweet spot:
# long 1-2hr podcasts make the word-level clip-detection prompt huge and unreliable.
DISCOVERY_VIDEO_DURATION=medium
ORCHESTRATOR_INTERVAL_SECONDS=120

# --- Engine (Lane C) ---
# Real pipeline: yt-dlp transcript + GPT moment detection (needs OPENAI_API_KEY).
OPENSHORTS_URL=http://localhost:8001
ENGINE_SCORING_PROVIDER=openai   # openai | gemini

# --- Upload-Post (Lane C posting to TikTok/IG/YouTube) ---
# Required for REAL rendering+posting + performance metrics. Without these, clips are
# detected (real moments) but render_status=pending / post_status=not_posted.
UPLOAD_POST_API_KEY=

# --- Performance (Lane B) ---
PATTERN_REFRESH_SECONDS=300

# --- Service URLs (for dashboard bridge) ---
DISCOVERY_API_URL=http://localhost:8000
NEXT_PUBLIC_DISCOVERY_API_URL=http://localhost:8000

# --- Direct YouTube upload (Google OAuth web client) ---
GOOGLE_CLIENT_ID=1093150024031-p1hm8k9cd8snlkcj1qtvbbl2aouhj58f.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OpenShorts runs as a Docker container; it must fetch prepared segments from the
# host engine via host.docker.internal, not localhost (which is the container itself).
ENGINE_PUBLIC_URL=http://host.docker.internal:8001

# --- Weights & Biases (Weave) tracing for the engine (Lane C) ---
# Paste your W&B key (from https://wandb.ai/authorize) after the = below.
# The engine auto-loads this .env, so no restart-time export is needed.
# (WEAVE_API_KEY is an accepted alias; the SDK reads WANDB_API_KEY.)
WANDB_API_KEY=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
WEAVE_PROJECT=clippilot

DISCOVERY_MAX_SOURCE_DURATION_SEC=1800
